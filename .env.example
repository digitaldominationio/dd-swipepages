# =============================================================================
# Swipe Toolkit — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=swipetoolkit
DATABASE_URL=postgresql://postgres:postgres@db:5432/swipetoolkit

# --- Application ---
NODE_ENV=production
PORT=3000

# --- Authentication ---
# A strong random string for signing JWTs (min 32 chars recommended)
JWT_SECRET=change-me-to-a-random-secret

# --- Encryption ---
# 64-char hex string (32 bytes) for AES-256-GCM encryption of stored API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-64-char-hex-string

# --- Initial Admin User (used by seed script on first run) ---
ADMIN_EMAIL=admin@swipetoolkit.com
ADMIN_PASSWORD=changeme123

# --- Docker Compose (optional overrides) ---
# DB_PORT=5432
# API_PORT=3000
